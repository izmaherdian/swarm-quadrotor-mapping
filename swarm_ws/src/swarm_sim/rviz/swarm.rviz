      Queue Size: 100
      Topic:
        Depth: 5
        Durability: Volatile
        History: Keep Last
        Reliability: Reliable
        Value: /iris_3/marker_visual
      Value: true
    - Class: rviz_default_plugins/Odometry
      Angle Tolerance: 0.1
      Axis Length: 0.0
      Axis Radius: 0.0
      Color: 255; 255; 0
      Enabled: true
      Keep: 1000
      Name: Drone_3_Trail
      Position Tolerance: 0.1
      Queue Size: 10
      Shape: Point
      Topic:
        Depth: 5
        Durability: Volatile
        History: Keep Last
